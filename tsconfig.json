{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@tagma/types": ["./node_modules/@tagma/sdk/plugins/types/src/index.ts"],
      "@tagma/sdk": ["./node_modules/@tagma/sdk/src/sdk.ts"]
    }
  },
  "include": ["src"]
}

  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["bun-types", "node"],
    "outDir": "./dist-server",
    "rootDir": "."
  },
  "include": ["server"]
}
